<?xml version="1.0"?>
<launch>

  <!--Drive robot rear wheels (servos)-->
  <include file="$(find-pkg-share agribot_launch)/launch/servo.launch"/>

  <!--Motor driver -->
  <include file="$(find-pkg-share md49_base_controller)/launch/md49_base_controller_local.launch"/>

  <!--Run Sensors -->
  <include file="$(find-pkg-share agribot_launch)/launch/sensors.launch"/>

  <include file="$(find-pkg-share agribot_description)/launch/display.launch"/>

  <node pkg="tf2_ros" exec="static_transform_publisher" name="link2_broadcaster"
        args="0 0 0 0 0 0 map odom" />

</launch>