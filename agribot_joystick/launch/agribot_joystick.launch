<launch>
  <arg name="joy_config" default="ps3" />
  <arg name="joy_dev" default="/dev/input/js0" />
  <arg name="agribot_joystick" default="$(find-pkg-share agribot_joystick)/config/agribot_joystick.yaml" />

  <node pkg="joy" exec="joy_node" name="joy_node">
    <param name="dev" value="$(var joy_dev)" />
    <param name="deadzone" value="0.3" />
    <param name="autorepeat_rate" value="20.0" />
  </node>
  <node pkg="agribot_joystick" exec="agribot_joystick" name="agribot_joystick" output="screen">
    <param from="$(var agribot_joystick)" />
  </node>
</launch>